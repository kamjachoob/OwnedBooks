@page
@model BookLibrary.Pages.BookPages.CreateModel
@{
    ViewData["Title"] = "Add New Book";
}

<div class="page-header">
    <h1>📖 Add New Book</h1>
    <p>Fill in the details to add a book to the library.</p>
</div>

<div class="card" style="max-width: 500px;">
    <form method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

        <div class="form-group">
            <label asp-for="Book.Title" class="control-label"></label>
            <input asp-for="Book.Title" class="form-control" placeholder="Enter book title" />
            <span asp-validation-for="Book.Title" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Book.Author" class="control-label"></label>
            <input asp-for="Book.Author" class="form-control" placeholder="Enter author name" />
            <span asp-validation-for="Book.Author" class="text-danger" style="font-size:12px;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Book.ISBN" class="control-label"></label>
            <input asp-for="Book.ISBN" class="form-control" placeholder="e.g., 978-0132350884" />
            <span asp-validation-for="Book.ISBN" class="text-danger" style="font-size:12px;"></span>
        </div>

        <button type="submit" class="btn btn-borrow" style="margin-top:10px;">Save Book</button>
        <a asp-page="./Index" style="display:inline-block; margin-left:10px; margin-top:10px; color:#3498db; text-decoration:none;">Cancel</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}